<header>

  <a href="#main" id="skip" title="skip to main content">skip to main content</a>

  <a class="site-title" href="/"
    {% if page.url == "/" %}aria-current="page"{% endif %}>home</a>

  <div class="folder-background"></div>

  <nav aria-label="main navigation">
    <ul>
      <li><a href="/about/"
        {% if "/about/" == page.url %}aria-current="page"{% endif %}>
        about</a></li>
      <li><a href="/blog/"
        {% if "/blog/" == page.url %}aria-current="page"{% endif %}>
        blog</a></li>
      <li><a href="/contact/"
        {% if "/contact/" == page.url %}aria-current="page"{% endif %}>
        contact</a></li>
    </ul>
  </nav>

</header>
